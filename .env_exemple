MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano-2025-08-07,gpt-5.1-chat-latest
BRAVE_SEARCH_API_KEY=
TORCH_NUM_THREADS=
OMP_NUM_THREADS=
# OCR Docling (schémas techniques, cotes, PDF scannés)
DOCLING_OCR_ENABLED=true
DOCLING_OCR_LANG=
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
HIERARCHICAL_CHUNK_SIZES=3072,1024,384
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
SECRET_KEY=
# SQLAlchemy : true = log toutes les requêtes (très verbeux ; les UPDATE d'embeddings remplissent les logs)
# DATABASE_ECHO=false
APP_NAME="LIA - L'Intelligence Artificielle"
MODEL_FAST=mistral-small-latest
MAX_COMPLETION_TOKENS=1024
SPACE_CHAT_MAX_TOKENS=900
SPACE_CHAT_TEMPERATURE=0.55
SPACE_CHAT_TOP_P=
# KAG - Knowledge Augmented Generation
KAG_ENABLED=true
KAG_EXTRACTION_PROVIDER=openai
KAG_EXTRACTION_MODEL=gpt-4o-mini
CORS_ALLOWED_ORIGINS=ds.proferm.net
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
HIERARCHICAL_CHUNK_SIZES=3072,1024,384
MULTIMODAL_ENABLED=true
# Journal dédié au traitement documents bibliothèque/espaces (défaut : logs/library_document_processing.log)
# LIBRARY_DOCUMENT_LOG_PATH=
# Vision : enrichissement des chunks « picture » via API Mistral (Pixtral)
VISION_MODEL=pixtral-12b-2409
VISION_MAX_TOKENS=1500
# Limite d’images analysées par document (vide = illimité)
# VISION_MAX_IMAGES_PER_DOCUMENT=30
DOCLING_OCR_ENABLED=true
DOCLING_OCR_LANG=fr,en
DOCLING_CPU_ONLY=true
DOCLING_USE_GPU=false
OCR_IMAGE_SCALE=3.0
OCR_PREPROCESS_ENABLED=true
OCR_FALLBACK_ENABLED=true
OCR_MIN_TEXT_LENGTH=50
OCR_TESSERACT_CONFIG=--oem 3 --psm 6 -l fra+eng
# Passages envoyés au LLM (chat espace / projet). 1 = risque élevé d'hallucinations ; 6–12 souvent pertinent.
RAG_TOP_K=8

# Redis + Celery (voir docs/CELERY.md)
# thread = file d'attente threads dans le process web (historique)
# celery = uniquement Celery (nécessite un worker)
# hybrid = Celery d'abord, repli threads si Redis indisponible
TASK_BACKEND_MODE=hybrid
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# RBAC Admin Bootstrap
# Email de l'utilisateur qui sera automatiquement administrateur
ADMIN_EMAIL=admin@example.com
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=noton-rag-kag
# Traces détaillées RAG/KAG dans LangSmith (texte des chunks, rerank, parents, prompts LLM)
TRACE_VERBOSE_TEXT=false
# Limite de caractères par chunk/message dans les traces (0 = illimité)
TRACE_TEXT_MAX_CHARS=12000