MISTRAL_API_KEY=
MISTRAL_BASE_URL=https://api.mistral.ai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano-2025-08-07,gpt-5.1-chat-latest
BRAVE_SEARCH_API_KEY=
OPENAI_IMAGE_MODEL=dall-e-3
TORCH_NUM_THREADS=
OMP_NUM_THREADS=
# OCR Docling (schémas techniques, cotes, PDF scannés)
DOCLING_OCR_ENABLED=true
DOCLING_OCR_LANG=
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
HIERARCHICAL_CHUNK_SIZES=3072,1024,384
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
SECRET_KEY=
APP_NAME="LIA - L'Intelligence Artificielle"
MODEL_FAST=mistral-small-latest
# KAG - Knowledge Augmented Generation
KAG_ENABLED=true
KAG_EXTRACTION_PROVIDER=openai
KAG_EXTRACTION_MODEL=gpt-4o-mini
CORS_ALLOWED_ORIGINS=ds.proferm.net
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DIMENSION=1024
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
HIERARCHICAL_CHUNK_SIZES=3072,1024,384
MULTIMODAL_ENABLED=true
DOCLING_OCR_ENABLED=true
DOCLING_OCR_LANG=fr,en
DOCLING_CPU_ONLY=true
DOCLING_USE_GPU=false
OCR_IMAGE_SCALE=3.0
OCR_PREPROCESS_ENABLED=true
OCR_FALLBACK_ENABLED=true
OCR_MIN_TEXT_LENGTH=50
OCR_TESSERACT_CONFIG=--oem 3 --psm 6 -l fra+eng
RAG_TOP_K=1